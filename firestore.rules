rules_version = '2';

// Public fact-bearing catalogue data + userProfiles ownership. The
// userProfiles rules below are the Phase 6 hardening promised in Phase 1
// -- see lib/../tests/firestore-rules.test.ts (run against the real
// Firebase emulator, not mocked) for what these are actually verified to
// do, not just claimed to do.
service cloud.firestore {
  match /databases/{database}/documents {

    // Public fact-bearing catalogue data: readable by anyone (this is a
    // public information site), never client-writable. All writes happen
    // server-side via the Admin SDK (ingestion pipeline, admin console).
    match /institutions/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /faculties/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /schools/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /programmes/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /apsRules/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /applicationWindows/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /subjects/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /bursaries/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /internships/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /statistics/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Internal to the ingestion pipeline and admin console -- no client
    // access at all, not even read.
    match /sources/{docId} {
      allow read, write: if false;
    }
    match /ingestionRuns/{docId} {
      allow read, write: if false;
    }
    match /verificationQueue/{docId} {
      allow read, write: if false;
    }

    // A learner's own profile. Per-user ownership plus the POPIA-relevant
    // invariants a client write must satisfy -- these are the actual
    // enforcement mechanism for "a minor's data requires guardian
    // consent," not just a UI convention a learner could bypass by
    // calling the Firestore SDK directly.
    match /userProfiles/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidProfileWrite(uid, request.resource.data);
      allow update: if isOwner(uid)
        && isValidProfileWrite(uid, request.resource.data)
        && consentRecordNotRemoved()
        && createdAtUnchanged();
      // Self-service account deletion (docs/MASTER_PROMPT_v2.md Phase 6:
      // "a working delete my account flow, not a stub") -- a signed-in
      // user may delete only their own profile document.
      allow delete: if isOwner(uid);
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // The document's own `uid` field must match the document ID (defense
    // in depth against any future code that trusts the field over the
    // path), and -- the actual POPIA enforcement -- a profile marked as a
    // minor's must carry a guardian-consent record, not self-consent.
    // Firestore rules can't verify a learner's real age; what they CAN
    // enforce is that the isMinor flag and the consent record are never
    // internally inconsistent.
    function isValidProfileWrite(uid, data) {
      return data.uid == uid
        && (
          data.isMinor == false
          || (
            data.consentRecord != null
            && data.consentRecord.consentedBy == "guardian"
            && data.guardianConsentAt != null
          )
        );
    }

    // Once a consent record exists, a client write can replace it (e.g.
    // re-confirming consent) but can never null it out -- consent is a
    // record to preserve, not a flag to toggle off from the client.
    function consentRecordNotRemoved() {
      return resource.data.consentRecord == null || request.resource.data.consentRecord != null;
    }

    function createdAtUnchanged() {
      return request.resource.data.createdAt == resource.data.createdAt;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
