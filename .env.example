# Copy to .env.local for local dev. Never commit a real .env* file --
# .gitignore already blocks .env, .env.local, .env.*.local.

# --- Client-safe (NEXT_PUBLIC_ prefix) ---------------------------------
# Firebase client SDK config. This is not a secret -- access to data is
# governed by Firestore/Storage security rules, not by hiding this config.
# See https://firebase.google.com/docs/projects/api-keys for why.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Base URL for absolute links in emails/PDFs. Falls back to VERCEL_URL in
# production (see lib/env/client.ts) -- only set this explicitly for local dev.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Set to "true" to connect to the local Firebase emulator suite instead of
# a real project -- run `firebase emulators:start` first (see .firebaserc,
# firebase.json). No real Firebase credentials needed in this mode; the
# NEXT_PUBLIC_FIREBASE_* vars above are ignored entirely when this is true.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# --- Server-only -- NEVER add a NEXT_PUBLIC_ prefix to any of these -----
# (CLAUDE.md non-negotiable #1: secrets never reach the browser)

# Firebase Admin SDK (service account) -- used server-side only, for
# Firestore/Auth writes that bypass client security rules (e.g. ingestion
# pipeline writes, admin console actions).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# LLM provider for the Phase 4 ingestion pipeline.
LLM_PROVIDER=
LLM_API_KEY=

# Shared secret every cron/admin route handler must check before running
# ingestion work -- a public cron endpoint is a free way to run up the bill.
CRON_SECRET=
